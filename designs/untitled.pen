                      "type": "text",
                      "id": "yN7Lw",
                      "name": "mobReaderPara2",
                      "fill": "$body-text",
                      "textGrowth": "fixed-width",
                      "width": 350,
                      "content": "When it arose in the Thought of the Simple Light to create the worlds, He contracted Himself (Tzimtzum) in the point of the center of His light, so that a vacant space was formed.",
                      "fontFamily": "$font-body",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
