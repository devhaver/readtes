                              "name": "t4mb3"
                            },
                            {
                              "type": "text",
                              "id": "c9Fg0B",
                              "name": "t4p3",
                              "fill": "$body-text",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "After the Tzimtzum, a Reshimu (impression) remained — a thin residue of the original light that could not be entirely removed from the vacated space.",
                              "lineHeight": 1.75,
                              "fontFamily": "$font-body",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
