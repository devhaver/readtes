                            {
                              "type": "text",
                              "id": "R1ysyl",
                              "name": "dmLeftQ1",
                              "fill": "#e8e4d8",
                              "textGrowth": "fixed-width",
                              "width": 268,
                              "content": "Question 1: Why are there specifically ten Sefirot?",
                              "fontFamily": "$font-body",
                              "fontSize": 14,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "QILNd",
                              "name": "dmLeftA1",
                              "fill": "#b0a898",
                              "textGrowth": "fixed-width",
                              "width": 268,
                              "content": "The number ten corresponds to the ten fundamental aspects of the Creator's desire to bestow. The ten Sefirot form the complete structure through which all spiritual reality is organized.",
                              "fontFamily": "$font-body",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            },
                            {
                              "type": "text",
                              "id": "PhbXb",
                              "name": "dmLeftQ2",
                              "fill": "#e8e4d8",
                              "textGrowth": "fixed-width",
                              "width": 268,
                              "content": "Question 2: What distinguishes Inner Light from Surrounding Light?",
                              "fontFamily": "$font-body",
                              "fontSize": 14,
                              "fontWeight": "600"
                            },
                            {
                              "type": "text",
                              "id": "HeBSB",
                              "name": "dmLeftA2",
                              "fill": "#b0a898",
                              "textGrowth": "fixed-width",
                              "width": 268,
                              "content": "The Inner Light fills the vessel according to its capacity. The Surrounding Light waits outside until the vessel is corrected and ready to receive more.",
                              "fontFamily": "$font-body",
                              "fontSize": 14,
                              "fontWeight": "normal"
                            }
                          ]
                        }
                      ]
                    },
