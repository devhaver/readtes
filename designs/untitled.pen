                              "name": "q1txt",
                              "fill": "$heading-text",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Question 1: Why are there specifically ten Sefirot?",
                              "fontFamily": "$font-body",
                              "fontSize": 14,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "UBN2w",
                          "name": "a1txt",
                          "fill": "$body-text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The number ten corresponds to the ten fundamental aspects of the Creator's desire to bestow. Just as the decimal system underlies all mathematics, the ten Sefirot form the complete structure through which all spiritual reality is organized.",
                          "lineHeight": 1.65,
                          "fontFamily": "$font-body",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        },
                        {
                          "type": "frame",
                          "id": "vf2qC",
                          "name": "q2row",
                          "width": "fill_container",
                          "gap": 8,
                          "children": [
                            {
                              "id": "wOWQZ",
                              "type": "ref",
                              "ref": "qHnnL",
                              "name": "mb2"
                            },
                            {
                              "type": "text",
                              "id": "K2iST",
                              "name": "q2txt",
                              "fill": "$heading-text",
                              "textGrowth": "fixed-width",
                              "width": "fill_container",
                              "content": "Question 2: What is the difference between the Inner Light and Surrounding Light?",
                              "fontFamily": "$font-body",
                              "fontSize": 14,
                              "fontWeight": "600"
                            }
                          ]
                        },
                        {
                          "type": "text",
                          "id": "ZRLoR",
                          "name": "a2txt",
                          "fill": "$body-text",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "The Inner Light (Ohr Pnimi) fills the vessel according to its capacity to receive. The Surrounding Light (Ohr Makif) waits outside the vessel until it is corrected and enlarged to receive more light.",
                          "lineHeight": 1.65,
                          "fontFamily": "$font-body",
                          "fontSize": 13,
                          "fontWeight": "normal"
                        }
                      ]
                    }
                  ]
                },
